# Database
DATABASE_URL="mysql://user:password@localhost:3306/labrats_master"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-33"
AUTH_URL="http://localhost:4567"

# Email (SMTP)
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your-email"
EMAIL_SERVER_PASSWORD="your-password"
EMAIL_FROM="noreply@yourstore.com"

# Cloudflare Turnstile (optional — forms work without these in dev)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Sentry (optional — error monitoring)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ShipStation Custom Store (optional — auth key configured in admin settings)
# No env vars needed — uses shipstation_auth_key setting in DB

# Seed (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-to-a-strong-password"

# App
NEXT_PUBLIC_APP_URL="http://localhost:4567"
